                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status OK', function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                                    "});",
                                    "pm.test('Response time < 3s', function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "POST Registrar Espontanea - Sin DNI",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/api/recepcion/espontanea",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "recepcion", "espontanea"]
                        },
                        "header": [
                            { "key": "Content-Type", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"nombre\": \"Test\", \"apellido\": \"Prueba\"}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 400 - validacion', function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([400, 422]);",
                                    "});",
                                    "pm.test('Response time < 3s', function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
