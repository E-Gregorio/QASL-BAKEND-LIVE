      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Assertions - Verificar estado post-SADE",
              "const cuit = pm.collectionVariables.get('testCuit');",
              "pm.test('Consulta exitosa (200)', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "if (body.totalCount > 0) {",
              "  pm.test('Registro encontrado por CUIT', () => {",
              "    pm.expect(body.totalCount).to.be.above(0);",
              "  });",
              "  pm.test('CUIT correcto: ' + cuit, () => {",
              "    pm.expect(body.data[0].cuit).to.equal(cuit);",
              "  });",
              "  const reg = body.data[0];",
              "  const status = reg.sadeStatus || 'null';",
              "  pm.test('sadeStatus actual: ' + status, () => {",
              "    pm.expect(reg.sadeStatus).to.be.oneOf(['EN_PROCESO', null, undefined]);",
              "  });",
              "  console.log('📋 Estado del registro:');",
              "  console.log('   CUIT:', reg.cuit);",
              "  console.log('   inconsistencyId:', reg.inconsistencyId);",
              "  console.log('   sadeStatus:', reg.sadeStatus);",
              "  // 🔍 DETECCIÓN FALSO POSITIVO: sadeLastError",
              "  if (reg.sadeLastError !== null) {",
              "    console.warn('⚠️ FALSO POSITIVO: sadeStatus=EN_PROCESO pero sadeLastError:', reg.sadeLastError);",
              "  }",
              "} else {",
              "  pm.test('CUIT ' + cuit + ' no encontrado en inconsistencias (puede haber migrado)', () => {",
              "    pm.expect(body.totalCount).to.equal(0);",
              "  });",
              "  console.warn('⚠️ CUIT no encontrado — posiblemente ya fue procesado completamente');",
              "}"
            ]
          }
        }
