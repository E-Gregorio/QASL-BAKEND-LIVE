        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Assertions - Generate Lot SADE (dinámico)",
              "const code = pm.response.code;",
              "const body = pm.response.json();",
              "const usedId = pm.collectionVariables.get('inconsistencyId');",
              "",
              "pm.test('SADE respondió (' + code + ') para ID: ' + usedId, () => {",
              "  pm.expect(code).to.be.oneOf([200, 400, 500]);",
              "});",
              "",
              "if (code === 200) {",
              "  pm.test('correlationId presente', () => {",
              "    pm.expect(body.correlationId).to.be.a('string').with.lengthOf.above(10);",
              "  });",
              "  pm.test('Inconsistencia en proceso', () => {",
              "    pm.expect(body.inconsistencyList[0].status).to.equal('EN_PROCESO');",
              "  });",
              "  // 🔗 Capturar correlationId",
              "  pm.collectionVariables.set('correlationId', body.correlationId);",
              "  console.log('✅ correlationId capturado:', body.correlationId);",
              "  console.log('🔗 INTEGRACIÓN: SIGMA → SADE expediente generado');",
              "} else {",
              "  pm.test('Error SADE: ' + (body.description || body.name || 'desconocido'), () => {",
              "    pm.expect(code).to.not.equal(200);",
              "  });",
              "  console.warn('⚠️ SADE rechazó ID ' + usedId + ':', body.description || JSON.stringify(body));",
              "  console.warn('   Causa probable: registro ya procesado o en estado inválido');",
              "}"
            ]
          }
        }
      ]
    },
