          "raw": "{\n  \"page\": 1,\n  \"pageSize\": 8,\n  \"sortBy\": \"cuit\",\n  \"sortDirection\": \"ASC\",\n  \"globalFilter\": \"{{testCuit}}\",\n  \"filterModel\": []\n}"
