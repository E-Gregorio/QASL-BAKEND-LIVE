    {
      "name": "10 - [INTEGRACIÓN EXTERNA] Consulta NCCT/PUC por CUIT",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseFEUrl}}/ncct/rest/puc/{{testCuit}}",
          "host": [
            "{{baseFEUrl}}/ncct/rest/puc/{{testCuit}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ⚠️ INTEGRACIÓN EXTERNA — Este endpoint es NCCT (sistema externo)",
              "// El HTTP 409 es el comportamiento ESPERADO si el CUIT no está en Padrón",
              "pm.test(\"Respuesta recibida de NCCT\", () => {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 409]);",
              "});",
              "",
              "const b = pm.response.json();",
              "if (pm.response.code === 409) {",
              "  pm.test(\"CUIT no encontrado en Padrón (409 esperado)\", () => {",
              "    pm.expect(b.success).to.equal(false);",
              "    pm.expect(b.message).to.include(\"CUIT\");",
              "  });",
              "  console.warn(\"⚠️ INTEGRACIÓN NCCT: CUIT no registrado en Padrón\");",
              "  console.warn(\"   Mensaje:\", b.message);",
              "  console.warn(\"   errorCode:\", b.errorCode);",
              "} else {",
              "  pm.test(\"CUIT encontrado en Padrón (200)\", () => {",
              "    pm.expect(b.success).to.not.equal(false);",
              "  });",
              "  console.log(\"✅ NCCT: CUIT válido en Padrón\");",
              "}",
              "// 🔍 NOTA QA: Si success:false con HTTP 200 → FALSO POSITIVO en integración NCCT"
            ]
          }
        }
      ]
    }
  ]
}