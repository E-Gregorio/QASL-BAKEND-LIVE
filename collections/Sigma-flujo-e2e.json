    {
      "name": "01 - Login / Validar Token",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}/login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Assertions - Login",
              "pm.test(\"Login exitoso (200)\", () => pm.response.to.have.status(200));",
              "pm.test(\"Username presente\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.username).to.equal(pm.collectionVariables.get(\"loginName\"));",
              "});",
              "pm.test(\"Roles asignados\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.roles).to.be.an(\"array\").with.lengthOf.at.least(1);",
              "});",
              "// 🔗 Capturar username para uso posterior",
              "const body = pm.response.json();",
              "if (body.username) pm.collectionVariables.set(\"loginName\", body.username);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Import Lote Inconsistencias (CSV)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/inconsistencies/lote-import?page=1&pageSize=10",
          "host": [
            "{{baseUrl}}/inconsistencies/lote-import?page=1&pageSize=10"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ⚠️ NOTA: Este endpoint usa multipart/form-data con archivo CSV",
              "// Para prueba manual: adjuntar archivo CSV con la inconsistencia",
              "// El body del CSV debe contener el CUIT: {{testCuit}}",
              "console.log(\"📤 Enviando archivo CSV para CUIT:\", pm.collectionVariables.get(\"testCuit\"));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Assertions - Lote Import (resiliente: si falla, el paso 03 captura ID dinámicamente)",
              "const code = pm.response.code;",
              "const body = pm.response.json();",
              "const bodyStr = JSON.stringify(body).toLowerCase();",
              "",
              "// Detectar caso especial: 500 por datos duplicados (re-ejecución del test)",
              "const isDuplicate = code === 500 && (bodyStr.includes('duplicad') || bodyStr.includes('ya existe'));",
              "",
              "pm.test('Endpoint respondió (' + code + ')' + (isDuplicate ? ' — DATOS DUPLICADOS' : ''), () => {",
              "  pm.expect(code).to.be.oneOf([200, 400, 422, 500]);",
              "});",
              "",
              "if (code === 200) {",
              "  pm.test('Filas válidas presentes', () => {",
              "    pm.expect(body.summary.validRows).to.be.at.least(1);",
              "  });",
              "  pm.test('Preview con datos', () => {",
              "    pm.expect(body.preview.data).to.be.an('array').with.lengthOf.at.least(1);",
              "  });",
              "  // 🔗 Capturar CUIT importado",
              "  if (body.preview && body.preview.data && body.preview.data[0]) {",
              "    const cuit = body.preview.data[0].cuit;",
              "    pm.collectionVariables.set('cuitImportado', cuit);",
              "    console.log('✅ CUIT importado capturado:', cuit);",
              "  }",
              "} else if (isDuplicate) {",
              "  pm.test('Datos duplicados detectados (re-ejecución)', () => {",
              "    pm.expect(isDuplicate).to.be.true;",
              "  });",
              "  console.warn('⚠️ DUPLICADO: El CUIT ya fue importado en una ejecución anterior');",
              "  console.warn('   Mensaje:', body.description || body.message || bodyStr.substring(0, 120));",
              "  console.warn('   El paso 03 capturará un ID fresco del ambiente');",
              "} else {",
              "  pm.test('Import requiere multipart con campos obligatorios (esperado sin CSV)', () => {",
              "    pm.expect(body.violations || body.title || body.description).to.not.be.undefined;",
              "  });",
              "  console.warn('⚠️ Import sin CSV/campos — El paso 03 capturará un ID fresco del ambiente');",
              "  if (body.violations) {",
              "    body.violations.forEach(v => console.warn('   →', v.field, ':', v.message));",
              "  }",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Consulta Inconsistencias (Lista General)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerToken}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/inconsistencies/query",
          "host": [
            "{{baseUrl}}/inconsistencies/query"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"page\": 1,\n  \"pageSize\": 8,\n  \"sortBy\": \"cuit\",\n  \"sortDirection\": \"ASC\",\n  \"globalFilter\": \"\",\n  \"filterModel\": []\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Assertions - Query Inconsistencias",
              "pm.test(\"Consulta exitosa (200)\", () => pm.response.to.have.status(200));",
              "pm.test(\"Data con registros\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.data).to.be.an(\"array\").with.lengthOf.at.least(1);",
              "});",
              "pm.test(\"totalCount mayor a cero\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.totalCount).to.be.above(0);",
              "});",
              "pm.test(\"Paginación correcta\", () => {",
              "  const b = pm.response.json();",
              "  pm.expect(b.page).to.equal(1);",
              "  pm.expect(b.pageSize).to.equal(8);",
              "});",
              "pm.test(\"inconsistencyId presente en registros\", () => {",
              "  const b = pm.response.json();",
              "  b.data.forEach(row => pm.expect(row.inconsistencyId).to.be.a(\"number\"));",
              "});",
              "",
              "// 🔗 CAPTURA DINÁMICA: Buscar inconsistencia FRESCA (sadeStatus null = no procesada)",
              "const body = pm.response.json();",
              "const fresca = body.data.find(row => !row.sadeStatus && row.sadeStatus !== 'EN_PROCESO');",
              "if (fresca) {",
              "  pm.collectionVariables.set('inconsistencyId', String(fresca.inconsistencyId));",
              "  pm.collectionVariables.set('testCuit', fresca.cuit);",
              "  console.log('🔗 Inconsistencia FRESCA capturada dinámicamente:');",
              "  console.log('   ID:', fresca.inconsistencyId, '| CUIT:', fresca.cuit);",
              "  console.log('   sadeStatus:', fresca.sadeStatus, '(disponible para procesar)');",
              "} else {",
              "  // Fallback: usar el primer registro disponible",
              "  const fallback = body.data[0];",
              "  if (fallback) {",
              "    pm.collectionVariables.set('inconsistencyId', String(fallback.inconsistencyId));",
              "    pm.collectionVariables.set('testCuit', fallback.cuit);",
              "    console.warn('⚠️ No se encontró inconsistencia con sadeStatus null, usando:', fallback.inconsistencyId);",
              "  }",
              "}",
              "pm.test('inconsistencyId capturado dinámicamente', () => {",
              "  const id = pm.collectionVariables.get('inconsistencyId');",
              "  pm.expect(id).to.be.a('string').with.lengthOf.above(0);",
              "  console.log('✅ inconsistencyId para el flujo:', id);",
              "});"
            ]
          }
        }
      ]
    },
