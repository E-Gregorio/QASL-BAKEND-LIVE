        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "{{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"page\":1,\"pageSize\":50,\"sortBy\":\"cuit\",\"sortDirection\":\"ASC\",\"globalFilter\":\"{{cuit}}\",\"filterModel\":[]}",
