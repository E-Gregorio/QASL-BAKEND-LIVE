              "if (!candidateId) {",
              "    pm.test('[ASYNC] candidateId vacio - SADE aun procesando lote', function () { pm.expect(true).to.be.true; });",
              "    console.log('ESPERADO: SADE procesa async, expediente no disponible aun');",
              "} else if (code === 200) {",
              "    const json = pm.response.json();",
              "    pm.test('Expediente generado exitosamente', function () { pm.response.to.have.status(200); });",
              "    console.log('correlationId: ' + json.correlationId);",
              "} else if (code === 500) {",
              "    pm.test('[CRITICO] Generar Expediente retorno 500', function () { pm.expect(code).to.eql(200); });",
              "    try { console.log('ERROR: ' + pm.response.text().substring(0, 500)); } catch(e) {}",
              "} else if (code === 504) {",
              "    pm.test('[CRITICO] Gateway Timeout 504', function () { pm.expect(code).to.eql(200); });",
              "}",
              "pm.test('Response time < 60s', function () { pm.expect(pm.response.responseTime).to.be.below(60000); });"
