  "item": [
    {
      "name": "01. Health Check - Feature Flags",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Status 200 - Backend HML accesible', function () { pm.response.to.have.status(200); });",
            "pm.test('Response es JSON valido', function () { pm.response.to.be.json; });",
            "pm.test('Feature flags contiene charge_module', function () {",
            "    const json = pm.response.json();",
            "    const flag = json.find(f => f.name === 'charge_module');",
            "    pm.expect(flag).to.not.be.undefined;",
            "    pm.expect(flag.active).to.be.true;",
            "});",
            "pm.test('Response time < 5s', function () { pm.expect(pm.response.responseTime).to.be.below(5000); });",
            "console.log('=== SIGMA HML - API E2E ===');",
            "console.log('Backend accesible: ' + pm.response.code);"
          ]
        }
      }],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "{{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/security/feature-flags",
          "host": ["{{baseUrl}}"],
          "path": ["security", "feature-flags"]
        }
      }
    },
    {
      "name": "02. Alta Inconsistencias - Import CSV",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const code = pm.response.code;",
            "const bodyText = pm.response.text().toLowerCase();",
            "const isDuplicate = code === 500 && (bodyText.includes('duplicad') || bodyText.includes('ya existe'));",
            "console.log('=== IMPORT CSV ===');",
            "console.log('Status: ' + code + (isDuplicate ? ' — DATOS DUPLICADOS' : ''));",
            "",
            "if (code === 200) {",
            "    const json = pm.response.json();",
            "    console.log('Total rows: ' + (json.summary ? json.summary.totalRows : 'N/A'));",
            "    console.log('Valid rows: ' + (json.summary ? json.summary.validRows : 'N/A'));",
            "    console.log('Invalid rows: ' + (json.summary ? json.summary.invalidRows : 'N/A'));",
            "    pm.test('Import exitoso - status 200', function () { pm.response.to.have.status(200); });",
            "    pm.test('Tiene rows validos', function () { pm.expect(json.summary.validRows).to.be.greaterThan(0); });",
            "    pm.test('Sin rows invalidos', function () { pm.expect(json.summary.invalidRows).to.eql(0); });",
            "} else if (isDuplicate) {",
            "    pm.test('Datos duplicados (re-ejecucion) - CUIT ya importado', function () { pm.expect(isDuplicate).to.be.true; });",
            "    console.log('DUPLICADO: El CUIT ya fue importado. Paso 03 capturara un ID fresco.');",
            "} else {",
            "    pm.test('Import CSV - Status: ' + code, function () { pm.expect(code).to.be.oneOf([200, 201]); });",
            "    try { console.log('Body: ' + pm.response.text().substring(0, 500)); } catch(e) {}",
            "}",
            "pm.test('Response time < 10s', function () { pm.expect(pm.response.responseTime).to.be.below(10000); });"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "{{authToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "C:/Users/Epidater/Desktop/Proyectos/qasl-backend-live/dummy_con_cuits_validos_rs_realistas.csv", "description": "Archivo CSV formato HML: coma separador, decimales entre comillas, fecha DD/MM/YY, regimen LO" },
            { "key": "campaniaCode", "value": "EXCLUSION_REGIMEN_SIMPLIFICADO", "type": "text" },
            { "key": "lineaInvestigacionCode", "value": "DENUNCIA", "type": "text" },
            { "key": "motivoCode", "value": "ACTIVIDAD_NO_DECLARADA", "type": "text" },
            { "key": "tributoCode", "value": "5", "type": "text" },
            { "key": "origen", "value": "PAF", "type": "text" },
            { "key": "userAudit", "value": "{{auditUser}}", "type": "text", "description": "OBLIGATORIO - sin esto 500 'auditUser is marked non-null but is null'" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/inconsistencies/lote-import?page=1&pageSize=10",
          "host": ["{{baseUrl}}"],
          "path": ["inconsistencies", "lote-import"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "pageSize", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "02B. Espera SADE - Procesamiento Import (40s)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const waitStart = pm.collectionVariables.get('importWaitStart');",
              "if (!waitStart) {",
              "    pm.collectionVariables.set('importWaitStart', String(Date.now()));",
              "    console.log('⏳ Iniciando espera de 40s para procesamiento SADE post-import...');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const waitStart = parseInt(pm.collectionVariables.get('importWaitStart') || '0');",
              "const elapsed = Math.round((Date.now() - waitStart) / 1000);",
              "const waitSeconds = 40;",
              "",
              "pm.test('Espera SADE: ' + elapsed + 's / ' + waitSeconds + 's', function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "if (elapsed < waitSeconds) {",
              "    console.log('⏳ SADE procesando... ' + elapsed + 's / ' + waitSeconds + 's');",
              "    postman.setNextRequest('02B. Espera SADE - Procesamiento Import (40s)');",
              "} else {",
              "    console.log('✅ Espera completada: ' + elapsed + 's — continuando flujo');",
              "    pm.collectionVariables.set('importWaitStart', '');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Accept", "value": "application/json" },
          { "key": "Authorization", "value": "{{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/security/feature-flags",
          "host": ["{{baseUrl}}"],
          "path": ["security", "feature-flags"]
        }
      }
    },
