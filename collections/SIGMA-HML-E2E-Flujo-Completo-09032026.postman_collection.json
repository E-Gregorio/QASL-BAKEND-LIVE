            "console.log('Total registros: ' + json.totalCount);",
            "pm.test('CUIT encontrado en inconsistencias', function () {",
            "    pm.expect(json.totalCount).to.be.greaterThan(0);",
            "    pm.expect(json.data.length).to.be.greaterThan(0);",
            "});",
            "if (json.data && json.data.length > 0) {",
            "    const record = json.data[0];",
            "    pm.collectionVariables.set('inconsistencyId', record.inconsistencyId);",
            "    console.log('inconsistencyId: ' + record.inconsistencyId);",
            "    console.log('CUIT: ' + record.cuit);",
            "    console.log('Status: ' + record.status);",
            "}"
          ]
        }
      }],
