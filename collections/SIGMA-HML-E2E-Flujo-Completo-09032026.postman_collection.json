    {
      "name": "04. Alta Inconsistencias - Generar Lote SADE",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.collectionVariables.get('inconsistencyId');",
              "console.log('=== GENERAR LOTE ===');",
              "console.log('inconsistencyId: ' + id);",
              "if (!id) { console.log('WARN: inconsistencyId vacio - import pudo haber fallado'); }"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const code = pm.response.code;",
              "console.log('Status: ' + code);",
              "if (code === 200) {",
              "    const json = pm.response.json();",
              "    console.log('correlationId: ' + json.correlationId);",
              "    if (json.correlationId) pm.collectionVariables.set('correlationId', json.correlationId);",
              "    pm.test('Lote generado exitosamente', function () { pm.response.to.have.status(200); });",
              "    pm.test('Tiene correlationId', function () { pm.expect(json.correlationId).to.not.be.undefined; });",
              "} else if (code === 500) {",
              "    pm.test('[CRITICO] Generar Lote retorno 500 - BUG BACKEND', function () { pm.expect(code).to.eql(200); });",
              "    try { console.log('ERROR 500 Body: ' + pm.response.text().substring(0, 500)); } catch(e) {}",
              "} else {",
              "    pm.test('Generar Lote - Status: ' + code, function () { pm.expect(code).to.be.oneOf([200, 201]); });",
              "}",
              "pm.test('Response time < 35s', function () { pm.expect(pm.response.responseTime).to.be.below(35000); });"
            ]
          }
        }
      ],
