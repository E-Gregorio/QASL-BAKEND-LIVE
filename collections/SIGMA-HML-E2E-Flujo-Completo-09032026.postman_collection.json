    {
      "name": "04B. SADE Polling - Esperar Seleccion",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const retryCount = parseInt(pm.collectionVariables.get('sadeRetryCount') || '0');",
              "const maxRetries = parseInt(pm.collectionVariables.get('sadeMaxRetries') || '12');",
              "if (retryCount === 0) {",
              "    pm.collectionVariables.set('sadeStartTime', String(Date.now()));",
              "    console.log('══════════════════════════════════════');",
              "    console.log('  SADE POLLING - ESPERAR SELECCION');",
              "    console.log('  Max reintentos: ' + maxRetries);",
              "    console.log('══════════════════════════════════════');",
              "}",
              "console.log('SADE Polling intento ' + (retryCount + 1) + '/' + maxRetries + '...');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const code = pm.response.code;",
              "if (code !== 200) {",
              "    pm.test('SADE Polling - Error HTTP ' + code, function () { pm.expect(code).to.eql(200); });",
              "    pm.collectionVariables.set('sadeRetryCount', '0');",
              "} else {",
              "    const json = pm.response.json();",
              "    const retryCount = parseInt(pm.collectionVariables.get('sadeRetryCount') || '0');",
              "    const maxRetries = parseInt(pm.collectionVariables.get('sadeMaxRetries') || '12');",
              "    const startTime = parseInt(pm.collectionVariables.get('sadeStartTime') || '0');",
              "    const elapsed = startTime ? Math.round((Date.now() - startTime) / 1000) : 0;",
              "",
              "    if (json.data && json.data.length > 0) {",
              "        pm.collectionVariables.set('sadeRetryCount', '0');",
              "        var sadeTime = elapsed + 's';",
              "        pm.collectionVariables.set('sadeSelectionTime', sadeTime);",
              "        console.log('SADE COMPLETO! CUIT en Seleccion tras ' + sadeTime + ' (' + (retryCount + 1) + ' intentos)');",
              "        pm.test('SADE proceso Seleccion en ' + sadeTime + ' (' + (retryCount + 1) + ' intentos)', function () { pm.expect(true).to.be.true; });",
              "        pm.test('CUIT disponible en Seleccion', function () { pm.expect(json.totalCount).to.be.greaterThan(0); });",
              "    } else if (retryCount < maxRetries - 1) {",
              "        pm.collectionVariables.set('sadeRetryCount', String(retryCount + 1));",
              "        console.log('SADE procesando... (' + elapsed + 's transcurridos)');",
              "        pm.test('SADE polling ' + (retryCount + 1) + '/' + maxRetries + ' (' + elapsed + 's) - esperando...', function () { pm.expect(true).to.be.true; });",
              "        postman.setNextRequest('04B. SADE Polling - Esperar Seleccion');",
              "    } else {",
              "        pm.collectionVariables.set('sadeRetryCount', '0');",
              "        pm.collectionVariables.set('sadeSelectionTime', 'TIMEOUT>' + elapsed + 's');",
              "        console.log('SADE TIMEOUT! ' + elapsed + 's sin procesar');",
              "        pm.test('[SADE TIMEOUT] ' + elapsed + 's - cola SADE saturada o servicio caido', function () { pm.expect(json.totalCount).to.be.greaterThan(0); });",
              "    }",
              "}"
            ]
          }
        }
      ],
