    {
      "name": "10B. SADE Polling - Esperar Expediente",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const retryCount = parseInt(pm.collectionVariables.get('sadeRetryCount') || '0');",
              "const maxRetries = parseInt(pm.collectionVariables.get('sadeMaxRetries') || '12');",
              "const candidateId = pm.collectionVariables.get('candidateId');",
              "if (!candidateId) {",
              "    console.log('SADE Polling Expediente SKIP - sin candidateId (flujo async pendiente)');",
              "}",
              "if (retryCount === 0) {",
              "    pm.collectionVariables.set('sadeStartTime', String(Date.now()));",
              "    console.log('══════════════════════════════════════');",
              "    console.log('  SADE POLLING - ESPERAR EXPEDIENTE');",
              "    console.log('  Max reintentos: ' + maxRetries);",
              "    console.log('══════════════════════════════════════');",
              "}",
              "console.log('SADE Polling Expediente intento ' + (retryCount + 1) + '/' + maxRetries + '...');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const code = pm.response.code;",
              "const candidateId = pm.collectionVariables.get('candidateId');",
              "if (!candidateId) {",
              "    pm.test('[ASYNC] Expediente polling skip - flujo SADE previo no completo', function () { pm.expect(true).to.be.true; });",
              "    pm.collectionVariables.set('sadeRetryCount', '0');",
              "    pm.collectionVariables.set('sadeExpedientTime', 'SKIP');",
              "} else if (code !== 200) {",
              "    pm.test('SADE Polling Expediente - Error HTTP ' + code, function () { pm.expect(code).to.eql(200); });",
              "    pm.collectionVariables.set('sadeRetryCount', '0');",
              "} else {",
              "    const json = pm.response.json();",
              "    const retryCount = parseInt(pm.collectionVariables.get('sadeRetryCount') || '0');",
              "    const maxRetries = parseInt(pm.collectionVariables.get('sadeMaxRetries') || '12');",
              "    const startTime = parseInt(pm.collectionVariables.get('sadeStartTime') || '0');",
              "    const elapsed = startTime ? Math.round((Date.now() - startTime) / 1000) : 0;",
              "",
              "    if (json.data && json.data.length > 0) {",
              "        pm.collectionVariables.set('sadeRetryCount', '0');",
              "        var sadeTime = elapsed + 's';",
              "        pm.collectionVariables.set('sadeExpedientTime', sadeTime);",
              "        var record = json.data[0];",
              "        pm.collectionVariables.set('expedientId', record.expedientId);",
              "        console.log('SADE COMPLETO! Expediente disponible tras ' + sadeTime);",
              "        console.log('expedientId: ' + record.expedientId);",
              "        pm.test('SADE proceso Expediente en ' + sadeTime + ' (' + (retryCount + 1) + ' intentos)', function () { pm.expect(true).to.be.true; });",
              "        pm.test('Expediente disponible en Aprobaciones', function () { pm.expect(json.totalCount).to.be.greaterThan(0); });",
              "    } else if (retryCount < maxRetries - 1) {",
              "        pm.collectionVariables.set('sadeRetryCount', String(retryCount + 1));",
              "        console.log('SADE Expediente procesando... (' + elapsed + 's transcurridos)');",
              "        pm.test('SADE polling expediente ' + (retryCount + 1) + '/' + maxRetries + ' (' + elapsed + 's)', function () { pm.expect(true).to.be.true; });",
              "        postman.setNextRequest('10B. SADE Polling - Esperar Expediente');",
              "    } else {",
              "        pm.collectionVariables.set('sadeRetryCount', '0');",
              "        pm.collectionVariables.set('sadeExpedientTime', 'TIMEOUT>' + elapsed + 's');",
              "        console.log('SADE Expediente TIMEOUT! ' + elapsed + 's sin procesar');",
              "        pm.test('[SADE TIMEOUT] Expediente ' + elapsed + 's - cola SADE saturada', function () { pm.expect(json.totalCount).to.be.greaterThan(0); });",
              "    }",
              "}"
            ]
          }
        }
      ],
