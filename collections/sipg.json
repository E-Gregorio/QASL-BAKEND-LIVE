      "name": "00 - AUTH",
      "description": "Autenticacion - Obtiene Bearer Token para toda la coleccion",
      "item": [
        {
          "name": "01. POST /api/v1/auth/login/ - Obtener Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login exitoso - Status 200\", function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "console.log(\"========================================\");",
                  "console.log(\"LOGIN RESPONSE\");",
                  "console.log(\"Status: \" + pm.response.code);",
                  "console.log(\"Keys: \" + Object.keys(jsonData).join(\", \"));",
                  "console.log(\"========================================\");",
                  "",
                  "var token = (jsonData.tokens && jsonData.tokens.access_token) ||",
                  "  jsonData.access || jsonData.token || jsonData.access_token ||",
                  "  (jsonData.data && (jsonData.data.access || jsonData.data.token)) || \"\";",
                  "",
                  "if (token) {",
                  "  pm.collectionVariables.set(\"bearerToken\", token);",
                  "  console.log(\"Token capturado: \" + token.substring(0, 30) + \"...\");",
                  "} else {",
                  "  console.log(\"WARN: Token no encontrado. Keys: \" + Object.keys(jsonData).join(\", \"));",
                  "}",
                  "",
                  "pm.test(\"Response time < 5s\", function() {",
                  "  pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"{{username}}\",\"password\":\"{{password}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login",
                ""
              ]
            }
          }
        }
